/*
 * Minimal nextflow.config for SaPhARI (matches template-style main.nf)
 * - Leaves all annotation parameters to CLI (they're passed on the command line)
 * - Provides sane defaults for cpus/memory/container that the CLI can override
 * - Defines simple profiles: local (default), docker, singularity
 */

params {
  // These are ONLY defaults and are overridden by the CLI flags: --cpus / --memory / --container
  cpus      = 4
  memory    = '8 GB'
  container = ''   // example: 'ghcr.io/org/saphari:latest' or 'saphari:0.1.0'
}

// Apply the resource defaults to all processes unless overridden
process {
  cpus   = params.cpus
  memory = params.memory

  // If a container image is provided via params.container (or CLI), use it
  if (params.container) {
    container = params.container
  }

  // Keep publish semantics inside main.nf (publishDir mode:'copy' is set there)
  // Error handling left to defaults; Nextflow retries transient failures automatically.
}

// Profiles:
// - local: run everything on the local executor (default behavior used by the CLI `-profile local`)
// - docker: enable Docker runtime; image is selected via --container (params.container)
// - singularity: enable Singularity/Apptainer runtime; image selected via --container
profiles {
  local {
    process.executor = 'local'
  }

  docker {
    docker.enabled = true
    process.executor = 'local'
  }

  singularity {
    singularity.enabled = true
    process.executor = 'local'
  }
}

/*
 * Notes:
 * - The CLI already sets the work directory (-work-dir) and NXF_HOME at runtime.
 * - All annotation/BLAST/DIAMOND parameter values (dimmatchamount, dimevalue, etc.) are
 *   passed via CLI and consumed by main.nf, so we do not duplicate them here.
 * - To set per-process resources, add scoped blocks below, e.g.:
 *
 *   process.withName: 'diamond' {
 *     cpus = 8
 *     memory = '16 GB'
 *   }
 *
 *   The CLI can still override global defaults via flags if desired.
 */
